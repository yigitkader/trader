# CLOB L2 API (emir gondermek icin)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# --- Guvenli baslangic ---
# dry_run: sadece log / plan. Canli emir icin live + asagidaki anahtarlar + POLYMARKET_LIVE_TRADING=1 gerekir.
POLYMARKET_EXECUTION_MODE=dry_run
POLYMARKET_LIVE_TRADING=0

# Canli emir icin: imzalayan cuzdanin 0x... private key'i (dry_run'da zorunlu degil)
POLYMARKET_PRIVATE_KEY=

POLYMARKET_CLOB_BASE=https://clob.polymarket.com

# --- Ag ve hesap modeli ---
POLYMARKET_CHAIN_ID=137
# 1 = Proxy (site/Magic hesabi). 0 = dogrudan EOA. 2 = Gnosis Safe
POLYMARKET_SIGNATURE_TYPE=1
POLYMARKET_FUNDER_ADDRESS=

# =============================================================================
# EMIR PARAMETRELERI
# =============================================================================
# Baz lot (bankroll tanimli degilse kullanilir)
POLYMARKET_ORDER_SIZE=10
POLYMARKET_PRICE_SLIPPAGE=0.02

# =============================================================================
# RISK LIMITLERI
# =============================================================================
# Spike yakalamak icin 90sn (eski: 120); ayni pazara asiri giris engeli hala korunuyor
POLYMARKET_COOLDOWN_SECS=90
# Spike aninda 3 farkli pazara ayni tick'te emir atabilmek icin (eski: 2)
POLYMARKET_MAX_ORDERS_PER_TICK=3
# DrPufferfish tarzi coklu pazar taramasi — daha genis sepet (eski: 5)
POLYMARKET_MAX_OPEN_MARKETS=8
# Gunluk limit: $300 (eski: $100). Bankroll $1000 ise ~%30 gunluk dongu
POLYMARKET_MAX_DAILY_NOTIONAL=300

# =============================================================================
# STRATEJI ESIKLERI
# =============================================================================
# Sharp bettor prensibi: edge net maliyetin ustunde olmali -> %3 (eski: 2.5%)
POLYMARKET_MIN_EDGE=0.03
# Fiyat kapisi: cok uc fiyatlarda likidite yok
POLYMARKET_MIN_OUTCOME_MID=0.03
POLYMARKET_MAX_OUTCOME_MID=0.97
# Baskin sinyal ayirici — dusuk tut ki FakeMove/Panic net ayrissin
POLYMARKET_DOMINANT_MIXED_MAX=0.005
POLYMARKET_DOMINANT_TIE_EPS=0.01
# 3 gun TTR penceresine uyumlu horizon (eski: 48h)
POLYMARKET_TIME_DECAY_HORIZON_HOURS=72
# TTR cezasi: 2 gun referans -> 3 gunluk pazar gerekli edge ~3.7%
POLYMARKET_TTR_EDGE_REF_SECS=172800
POLYMARKET_TTR_EDGE_EXPONENT=0.5
# Daha derin L2 -> daha guvenilir imbalance sinyali (eski: 120/5)
POLYMARKET_BOOK_MAX_TOKENS=200
POLYMARKET_BOOK_DEPTH_LEVELS=8
# Kisa vadeli piyasalara biraz daha oncelik (eski: 0.12)
POLYMARKET_SCORER_TTR_SCALE_EXP=0.15
# Longshot: ucuz YES + kisa TTR -> NO tarafi edge
POLYMARKET_LONGSHOT_ENABLED=1
POLYMARKET_LONGSHOT_YES_MAX=0.06
POLYMARKET_LONGSHOT_TTR_MAX_SECS=259200
POLYMARKET_LONGSHOT_RAW_WEIGHT=0.35
# Multi-outcome arbitraj tespiti
POLYMARKET_MULTI_ARB_SUM_LOW=0.98
POLYMARKET_MULTI_ARB_SUM_HIGH=1.02

# =============================================================================
# TRADE POLICY (dominant allowlist)
# =============================================================================
# Tuner sonucu: FakeMove + Panic en yuksek proxy EV
POLYMARKET_TRADE_DOMINANT_ALLOW=FakeMove,Panic

# =============================================================================
# EXIT POLICY
# =============================================================================
# Proxy analiz (cost=1%): next60 en yuksek EV -> paper exit gozlem ufku
POLYMARKET_EXIT_AFTER_OBS=60

# =============================================================================
# SINYAL ESIKLERI (tape / absorption)
# =============================================================================
# 2sn tick + L2 midpoint icin dusuk tutulmus esikler
POLYMARKET_FAKE_MOMENTUM_THRESHOLD=0.0005
POLYMARKET_FAKE_REACTION_MIN=0.00001
# Daha hassas panic tespiti — haber spike'lari yakalamak icin (eski: 0.0015)
POLYMARKET_PANIC_SPIKE_THRESHOLD=0.001
POLYMARKET_ABSORPTION_MIN_TRADES=1
POLYMARKET_ABSORPTION_MAX_MOMENTUM=0.02
POLYMARKET_ABSORPTION_PRESSURE_DEADBAND=0.005
POLYMARKET_ABSORPTION_PRESSURE_SCALE=0.35

# =============================================================================
# EXECUTION: Kelly + maker/taker
# =============================================================================
POLYMARKET_ORDER_STYLE=maker
POLYMARKET_MAKER_STRICT=0
# !! BANKROLL: Hesabindaki gercek USDC bakiyesini yaz.
# Lot = kasa x [min_frac..max_frac] x guc (Kelly+confidence)
# Ornek: $1000 bankroll, %1-%12 band, half-Kelly -> yuksek guvende ~$120, dusuk ~$10
POLYMARKET_BANKROLL_USDC=1000
POLYMARKET_BANKROLL_MIN_FRAC=0.01
POLYMARKET_BANKROLL_MAX_FRAC=0.12
# Half-Kelly: sharp bettor guvenlik marji
POLYMARKET_KELLY_FRACTION=0.5
POLYMARKET_KELLY_TARGET=0.08
POLYMARKET_ORDER_SIZE_MIN=1
# Yuksek conviction'da daha buyuk pozisyon (eski: 50)
POLYMARKET_ORDER_SIZE_MAX=100

# =============================================================================
# PAZAR TARAMA
# =============================================================================
# 3 gun pencere: haber/jeopolitik olaylari yakalamak icin (eski: 86400 = 1 gun)
# SecondWindCapital Iran piyasasindan $935K kazandi — bu tip olaylar 1-3 gun TTR
POLYMARKET_MAX_TTR_SECS=259200
