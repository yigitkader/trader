# Kopyala: cp .env.example .env  (`.env` gitignore'da; asla commit etme)

# ─── Güvenli önerilen başlangıç ───
# dry_run: sadece log / plan. Canlı emir için live + aşağıdaki anahtarlar + POLYMARKET_LIVE_TRADING=1 gerekir.
POLYMARKET_EXECUTION_MODE=dry_run
# Gerçek POST /order kapalı (açmak için: 1 veya true veya yes)
POLYMARKET_LIVE_TRADING=0

# CLOB L2 API — Polymarket’ten alınan anahtarlar (API key UUID formatında olmalı)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Canlı emir için: imzalayan cüzdanın 0x… private key’i (dry_run’da zorunlu değil)
POLYMARKET_PRIVATE_KEY=

POLYMARKET_CLOB_BASE=https://clob.polymarket.com

# ─── Ağ ve hesap modeli (üretim için önerilen) ───
# Polymarket ana ağı Polygon → 137. Test: 80002 (Amoy)
POLYMARKET_CHAIN_ID=137
# 1 = Proxy: sitede/Magic ile açılan çoğu hesap (önerilen). 0 = doğrudan EOA cüzdan. 2 = Gnosis Safe
POLYMARKET_SIGNATURE_TYPE=1
# Proxy/Safe: genelde boş bırak (SDK proxy adresini türetebilir). Emir reddedilirse Polymarket’teki funding adresini yaz
POLYMARKET_FUNDER_ADDRESS=

# ─── Emir parametreleri (küçük başlamak için önerilen) ───
POLYMARKET_ORDER_SIZE=5
POLYMARKET_PRICE_SLIPPAGE=0.02

# ─── Risk limitleri ───
# Aynı pazara tekrar emir: en az 120sn bekle
POLYMARKET_COOLDOWN_SECS=120
# Bir tick'te (2sn) atılabilecek maks emir
POLYMARKET_MAX_ORDERS_PER_TICK=2
# Aynı anda farklı pazara açık emir üst sınırı
POLYMARKET_MAX_OPEN_MARKETS=5
# Günlük toplam emir tutarı (USDC)
POLYMARKET_MAX_DAILY_NOTIONAL=100

# ─── Strateji eşikleri (motor / feature) ───
# |model_prob − yes_mid| bu değerin altındaysa Skip
POLYMARKET_MIN_EDGE=0.025
# Fiyat kapısı: bu aralığın dışındaki outcome mid’lerde işlem yok
POLYMARKET_MIN_OUTCOME_MID=0.03
POLYMARKET_MAX_OUTCOME_MID=0.97
# Baskın sinyal: tümü bu değerin altındaysa Mixed
POLYMARKET_DOMINANT_MIXED_MAX=0.05
# İki sinyal gücü bu kadar yakınsa “berabere” say
POLYMARKET_DOMINANT_TIE_EPS=0.02
# time_decay: bu saatten uzak vadelerde decay=0; yakında karesel artış
POLYMARKET_TIME_DECAY_HORIZON_HOURS=48
# TTR cezası: gerekli |edge| = MIN_EDGE * (ttr/ref)^EXP (uzun kilit → daha yüksek bar)
POLYMARKET_TTR_EDGE_REF_SECS=86400
POLYMARKET_TTR_EDGE_EXPONENT=0.5
# Tick başına CLOB L2 çekilecek max token (YES+NO birlikte); 0 = kitap/imbalance kapalı
POLYMARKET_BOOK_MAX_TOKENS=120
POLYMARKET_BOOK_DEPTH_LEVELS=5
# Skor öncesi: raw *= (TTR_REF/ttr)^EXP — kısa vadeli piyasaya öncelik
POLYMARKET_SCORER_TTR_SCALE_EXP=0.12
# Ucuz YES + kısa TTR: NO tarafına eğim (0=kapalı)
POLYMARKET_LONGSHOT_ENABLED=1
POLYMARKET_LONGSHOT_YES_MAX=0.06
POLYMARKET_LONGSHOT_TTR_MAX_SECS=259200
POLYMARKET_LONGSHOT_RAW_WEIGHT=0.35
# 3+ sonuçlu piyasada Σmid eşikleri (tespit; otomatik emir yok)
POLYMARKET_MULTI_ARB_SUM_LOW=0.98
POLYMARKET_MULTI_ARB_SUM_HIGH=1.02

# ─── Execution: Kelly + maker/taker ───
# maker = spread içine limit (ücret/latency); taker = ask altında sıkıştırılmış agresif limit
POLYMARKET_ORDER_STYLE=maker
# 1 = L2 yoksa veya dar spread’te maker emri gönderme (profesyonel maker)
POLYMARKET_MAKER_STRICT=0
# Kasayı USDC olarak ver; lot = kasa × (MIN_FRAC…MAX_FRAC) × güç (Kelly+confidence). Boş = sadece ORDER_SIZE × Kelly
# POLYMARKET_BANKROLL_USDC=1000
POLYMARKET_BANKROLL_MIN_FRAC=0.01
POLYMARKET_BANKROLL_MAX_FRAC=0.10
# Kelly * bu katsayı (0.5 ≈ Half-Kelly)
POLYMARKET_KELLY_FRACTION=0.5
# Bu efektif Kelly’de lot çarpanı ~1.0
POLYMARKET_KELLY_TARGET=0.08
POLYMARKET_ORDER_SIZE_MIN=1
POLYMARKET_ORDER_SIZE_MAX=50

# Pazar tarama: çözüme en fazla ne kadar süre kalsın (sn). Boş → kod 86400 (24sa) kullanır. Tüm vadeler: 0
POLYMARKET_MAX_TTR_SECS=86400
