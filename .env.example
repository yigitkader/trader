# Kopyala: cp .env.example .env  (`.env` gitignore'da)

# dry_run | live
POLYMARKET_EXECUTION_MODE=dry_run

# CLOB L2 API (emir göndermek için — resmi dokümantasyona göre doldur)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# (İSTEĞE BAĞLI) Cüzdan private key — şu anki iskelette kullanılmıyor.
# Gerçek CLOB emrinde EIP-712 / on-chain imza hangi yöntemle yapılacaksa o zaman eklenecek.
# O satırı .env'de hiç yazmaman normaldir.
# POLYMARKET_PRIVATE_KEY=

POLYMARKET_CLOB_BASE=https://clob.polymarket.com

# Çözüme kalan süre üst limiti (saniye). Tanımsız/boş → varsayılan 86400 (24 saat).
# Tüm vadeler: 0
# 90 gün: 7776000
# POLYMARKET_MAX_TTR_SECS=86400
